@page "/{*Path}"

<PageTitle>Page Not Found</PageTitle>

<section class="page-shell">
    <section class="panel">
        <p class="eyebrow">Route Not Found</p>
        <h1>That page does not exist.</h1>
        <p class="page-intro">
            The route could not be matched, so the app stayed responsive and brought you to a safe fallback.
        </p>
        @if (!string.IsNullOrWhiteSpace(Path))
        {
            <p><strong>Requested path:</strong> /@Path</p>
        }
        <a class="action-primary" href="/">Return to overview</a>
    </section>
</section>

@code {
    [Parameter]
    public string? Path { get; set; }
}
