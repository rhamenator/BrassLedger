@inject NavigationManager NavigationManager
@inject BrassLedger.Infrastructure.Persistence.IBootstrapWorkspaceService BootstrapWorkspaceService

<section class="panel">
    <p class="eyebrow">Authentication Required</p>
    <h1>Redirecting to sign-in.</h1>
    <p class="page-intro">
        This workspace requires an authenticated operator before any accounting data is loaded.
    </p>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var targetPath = string.IsNullOrWhiteSpace(relativePath) ? "/" : $"/{relativePath}";
        var destination = await BootstrapWorkspaceService.RequiresSetupAsync()
            ? "/setup"
            : $"/login?returnUrl={Uri.EscapeDataString(targetPath)}";

        NavigationManager.NavigateTo(destination, forceLoad: true);
    }
}
